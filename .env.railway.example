# Variáveis para deploy no Railway (copie para Shared Variables ou por serviço).
# NÃO commite segredos reais — use o painel Railway ou `railway variables`.

# --- PostgreSQL (plugin Railway → referência automática na API) ---
# DATABASE_URL=postgresql://...

# --- API (serviço connect-api, root: api/) ---
ENVIRONMENT=Production
KEYCLOAK_REALM=luxus
KEYCLOAK_RESOURCE=connect-cli

# Teste de monitoramento: API não sobe (exit 1 / crash loop no Railway). Remova após o teste.
# MONITORING_TEST_ENABLED=true

# URL interna do Keycloak (outro serviço Railway ou externo)
KEYCLOAK_AUTH_SERVER_URL=https://SEU-KEYCLOAK.up.railway.app
# URL que o browser usa (mesma ou proxy público)
KEYCLOAK_PUBLIC_AUTH_SERVER_URL=https://SEU-DOMINIO/auth
KEYCLOAK_ADMIN_USERNAME=admin
KEYCLOAK_ADMIN_PASSWORD=
# Origens do frontend (domínio público do connect-web)
CORS_ORIGINS=https://SEU-WEB.up.railway.app

# RabbitMQ (CloudAMQP, plugin ou outro serviço) — opcional
RABBITMQ_URL=amqp://user:pass@host/vhost

# Object storage S3-compatível (R2, MinIO, etc.)
OBJECT_STORAGE_SERVICE_URL=https://...
OBJECT_STORAGE_PUBLIC_URL=https://...
OBJECT_STORAGE_ACCESS_KEY_ID=
OBJECT_STORAGE_SECRET_ACCESS_KEY=

# SMTP (opcional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_TLS=true

# Sicredi — produção
SICREDI_ENABLED=true
SICREDI_SANDBOX=false
SICREDI_API_KEY=
SICREDI_USERNAME=
SICREDI_PASSWORD=
SICREDI_COOPERATIVA=
SICREDI_POSTO=
SICREDI_CODIGO_BENEFICIARIO=
SICREDI_WEBHOOK_TOKEN=
SICREDI_AUTO_REGISTER_WEBHOOK=true
# Use o domínio público da API no Railway (gerado automaticamente se vazio)
# SICREDI_PUBLIC_API_URL=https://SEU-API.up.railway.app

# --- Web (serviço connect-web, root: src/Luxus.Connect.Web/) ---
# Build-time (Variables → marque como disponível no build):
VITE_API_URL=https://SEU-API.up.railway.app
VITE_AUTH_URL=https://SEU-DOMINIO/auth
VITE_CLIENT_ID=connect-cli
VITE_CLIENT_SECRET=
VITE_STORAGE_BUCKET_NAME=luxus-connect
