# Copie para .env na raiz do repositório na VPS (ou mescle com o .env existente).
# Usado por docker-compose.prod.yml — não commite segredos.

POSTGRES_USER=postgres
POSTGRES_PASSWORD=

SEQ_PWD_HASH=

KC_ADMIN_PWD=
KC_DB_USERNAME=postgres
KC_DB_PASSWORD=

RMQ_USER=guest
RMQ_PWD=guest

# Secret do client Keycloak (connect-cli) — deve coincidir com o realm.
# No admin do Keycloak, ajuste redirect URIs / web origins para o teu domínio HTTPS.
KC_CLIENT_SECRET=

OBJECT_STORAGE_SERVICE_URL=
OBJECT_STORAGE_ACCESS_KEY_ID=
OBJECT_STORAGE_SECRET_ACCESS_KEY=

# Opcional
# TAG=latest
