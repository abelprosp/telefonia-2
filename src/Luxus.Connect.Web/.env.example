# Copie para `.env` na pasta deste projeto. Variáveis VITE_* são expostas ao bundle do browser.
VITE_API_URL=http://localhost:5193
VITE_AUTH_URL=http://localhost:8081
VITE_CLIENT_ID=connect-cli
# Secret do client Keycloak (confidencial); em dev local costuma ser o mesmo do realm `luxus`.
VITE_CLIENT_SECRET=
VITE_STORAGE_BUCKET_NAME=luxus-connect

# Docker Compose (Vite em connect-web-dev): o compose pode injetar KC_CLIENT_SECRET na raiz do repo.
