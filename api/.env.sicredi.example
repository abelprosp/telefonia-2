# Sicredi API de Cobrança — Luxus Telefonia Ltda
# Portal: https://developer.sicredi.com.br

SICREDI_ENABLED=true
SICREDI_SANDBOX=true

# x-api-key do portal (Sandbox ou Produção — nunca misturar)
SICREDI_API_KEY=

# Código de acesso gerado no Internet Banking → Cobrança → Código de Acesso
SICREDI_PASSWORD=

# Username OAuth: beneficiário + cooperativa (ex.: 010480179)
# Se vazio, monta automaticamente: SICREDI_CODIGO_BENEFICIARIO + SICREDI_COOPERATIVA
SICREDI_USERNAME=010480179

# Convênio Luxus
SICREDI_COOPERATIVA=0179
SICREDI_POSTO=14
SICREDI_CODIGO_BENEFICIARIO=01048

# URL pública da API (para registrar webhook no Sicredi)
# Ex.: https://api.suaempresa.com.br
SICREDI_PUBLIC_API_URL=

# Token que o Sicredi enviará no header Authorization do webhook
SICREDI_WEBHOOK_TOKEN=
